GATEWAY_BIND=0.0.0.0:8080
PUBLISHED_GATEWAY_PORT=8080

BACKEND_UPSTREAMS=backend-a:8080:1,backend-b:8080:1
BACKEND_UPSTREAM=

LB_STRATEGY=round_robin
SLOW_START_WINDOW=0
CONSISTENT_HASH_KEY=remote_addr
CONSISTENT_HASH_HEADER=X-Request-ID

SESSION_STICKY=true
SESSION_STICKY_MODE=cookie
SESSION_COOKIE_NAME=OPENRESTY_LB_ROUTE
SESSION_HEADER_NAME=X-Session-ID
SESSION_TTL=3600s

HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=5s
HEALTH_CHECK_PATH=/healthz
HEALTH_CHECK_TIMEOUT=2s
HEALTH_CHECK_FAILS=3
HEALTH_CHECK_PASSES=2
HEALTH_CHECK_STATUS_CODES=200-399
HEALTH_CHECK_BODY_MATCH=
HEALTH_CHECK_BODY_MATCH_NEGATE=false
HEALTH_CHECK_HEADER_NAME=
HEALTH_CHECK_HEADER_MATCH=
HEALTH_CHECK_MANDATORY=false

# Redis 跨节点同步（可选）
REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

UPSTREAM_MAX_CONNS=0
UPSTREAM_QUEUE_SIZE=0
UPSTREAM_QUEUE_TIMEOUT=30

CIRCUIT_BREAKER_ENABLED=false
CIRCUIT_BREAKER_FAILS=5
CIRCUIT_BREAKER_TIMEOUT=30

PROXY_CONNECT_TIMEOUT=3s
PROXY_READ_TIMEOUT=30s
PROXY_SEND_TIMEOUT=30s
DNS_RESOLVER="127.0.0.11 ipv6=off valid=10s"

TLS_CERT_FILE=
TLS_KEY_FILE=

API_GATEWAY_SECRET=change-me

BACKEND_FIXTURE_PORT=8080
BACKEND_A_ID=backend-a
BACKEND_B_ID=backend-b
