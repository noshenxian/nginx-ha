GATEWAY_BIND=0.0.0.0:8080

# 上游列表（必填，格式 host:port:weight,...）
BACKEND_UPSTREAMS=backend-a:8080:1,backend-b:8080:1

# 多组上游（可选，location 级别通过 set $upstream_group xxx 切换）
# BACKEND_UPSTREAMS_app=10.0.0.1:8080:2,10.0.0.2:8080:1
# BACKEND_UPSTREAMS_api=10.0.0.10:8080:1,10.0.0.11:8080:1

# 管理端点密钥（必填）
API_GATEWAY_SECRET=change-me

# 负载均衡策略：round_robin / ip_hash / least_conn / consistent_hash
LB_STRATEGY=round_robin

# 会话保持
SESSION_STICKY=true
SESSION_STICKY_MODE=cookie
SESSION_COOKIE_NAME=OPENRESTY_LB_ROUTE
SESSION_TTL=3600s

# 主动健康检查
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=5s
HEALTH_CHECK_PATH=/healthz
HEALTH_CHECK_TIMEOUT=2s
HEALTH_CHECK_FAILS=3
HEALTH_CHECK_PASSES=2

# 代理超时
PROXY_CONNECT_TIMEOUT=3s
PROXY_READ_TIMEOUT=30s
PROXY_SEND_TIMEOUT=30s

# DNS 解析器
DNS_RESOLVER="127.0.0.11 ipv6=off valid=10s"

# --- 以下为可选高级功能，不设即关闭 ---

# Redis 跨节点同步
# REDIS_ENABLED=true
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# 连接上限 + 排队
# UPSTREAM_MAX_CONNS=100
# UPSTREAM_QUEUE_SIZE=50
# UPSTREAM_QUEUE_TIMEOUT=30

# 熔断
# CIRCUIT_BREAKER_ENABLED=true
# CIRCUIT_BREAKER_FAILS=5
# CIRCUIT_BREAKER_TIMEOUT=30

# HTTPS（需要同时设置 cert 和 key 路径）
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem
